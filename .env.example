# Servidor
PORT=3020
NODE_ENV=development

# Base de datos PostgreSQL
DATABASE_URL=postgres://solares:solares123@localhost:5432/venta_solares
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000

# Seguridad
JWT_SECRET=change-me-in-production-min-32-chars-long-secret
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=10

# Logging
LOG_LEVEL=info

# CORS (lista de orígenes permitidos separados por coma; vacío = solo mismo origen)
CORS_ORIGINS=

# Scheduler de mora (formato HH:mm en zona local)
LATE_FEE_JOB_TIME=02:00
